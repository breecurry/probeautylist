NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pro_beauty_list
SESSION_SECRET=replace-with-a-unique-random-secret-at-least-64-characters
APP_ORIGIN=http://localhost:5173
TRUST_PROXY=0
DATABASE_SSL_MODE=disable
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
# Optional one-time initial admin bootstrap for npm run admin:create.
# Remove ADMIN_PASSWORD from production after the admin account is created.
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=change-this-before-running-admin-create
