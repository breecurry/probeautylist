{
  "name": "pro-beauty-list",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted marketplace and booking platform for beauty professionals and clients.",
  "scripts": {
    "dev": "tsx server/src/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "npm run check && vite build && tsc -p server/tsconfig.json",
    "start": "node dist/server/index.js",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "admin:create": "tsx server/src/scripts/create-admin.ts",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "smoke:health": "node scripts/smoke-health.mjs",
    "e2e:local": "node scripts/e2e-local.mjs",
    "verify": "npm run lint && npm run build && npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@clerk/express": "^2.1.26",
    "@clerk/react": "^6.9.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^22.16.3",
    "@types/pg": "^8.15.4",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.30.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
